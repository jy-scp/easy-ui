{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@easy/ui": [
        "../components/src"
      ]
    },
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "vite/client"
    ]
  },
  "include": [
    "src",
    "main.tsx",
    "index.html"
  ]
}
